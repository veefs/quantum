# Build artifacts
build/
*.exe
*.o
*.obj

# Qt moc-generated files (regenerated by build.ps1 on every build)
src/moc_*.cpp

# Generated chart images (created at runtime by the python scripts)
resources/*.png
!resources/QST.png
!resources/quantumv5.png
!resources/buttons/
scripts/resources/

# Stray chart PNGs that sometimes land in the project root if a script
# runs from the wrong working directory
/*.png

# Editor / OS noise
.vscode/
*.user
Thumbs.db
.DS_Store
